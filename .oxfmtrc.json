{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "avoid",
  "ignorePatterns": [
    "*dist",
    "*generated",
    "packages/components/shared/src/vendor",
    "packages/tokens/src/tokens",
    "website"
  ],
  "insertFinalNewline": true,
  "jsdoc": true,
  "jsdoc.capitalizeDescriptions": false,
  "printWidth": 100,
  "singleQuote": true,
  "sortPackageJson": false,
  "tabWidth": 2,
  "trailingComma": "none"
}
