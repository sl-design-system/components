{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "avoid",
  "ignorePatterns": ["*dist", "*generated", "packages/tokens/src/tokens", "website"],
  "insertFinalNewline": true,
  "jsdoc": true,
  "printWidth": 100,
  "singleQuote": true,
  "sortPackageJson": false,
  "tabWidth": 2,
  "trailingComma": "none"
}
