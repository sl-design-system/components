<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | SL Design System</title>
  <link rel="stylesheet" href="/theme/fonts.css">
  <link rel="stylesheet" href="/theme/light.css">
  <link rel="stylesheet" href="/theme/global.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <div class="site-layout">
    <nav class="sidebar" aria-label="Main navigation">
      <div class="sidebar__header">
        <a href="/" class="sidebar__logo">SL Design System</a>
      </div>
      {% include "sidebar.njk" %}
    </nav>

    <main class="content">
      <h1>{{ title }}</h1>
      {{ content | safe }}
    </main>

    <aside class="toc" aria-label="On this page">
      <div class="toc__container">
        <h2 class="toc__title">On this page</h2>
        <nav class="toc__nav" id="toc-nav"></nav>
      </div>
    </aside>
  </div>

  {% include "toc.njk" %}
</body>
</html>
