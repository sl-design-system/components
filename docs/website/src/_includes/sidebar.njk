{%- macro renderNav(entries, activePage) -%}
  <ul class="nav-list">
    {%- for entry in entries -%}
      {%- set isActive = (entry.url == activePage) -%}
      {%- set hasChildren = entry.children | length -%}
      {%- set hasActiveChild = false -%}
      {%- if hasChildren -%}
        {%- for child in entry.children -%}
          {%- if child.url == activePage -%}
            {%- set hasActiveChild = true -%}
          {%- endif -%}
          {%- if child.children | length -%}
            {%- for grandchild in child.children -%}
              {%- if grandchild.url == activePage -%}
                {%- set hasActiveChild = true -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      <li class="nav-item">
        {%- if hasChildren -%}
          <details{{ ' open' if (isActive or hasActiveChild) }}>
            <summary class="nav-link{{ ' is-active' if isActive }}">
              {%- if entry.url -%}
                <a href="{{ entry.url }}">{{ entry.title }}</a>
              {%- else -%}
                {{ entry.title }}
              {%- endif -%}
            </summary>
            {{ renderNav(entry.children, activePage) }}
          </details>
        {%- else -%}
          <a href="{{ entry.url }}" class="nav-link{{ ' is-active' if isActive }}">{{ entry.title }}</a>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
{%- endmacro -%}

{%- set navPages = collections.all | eleventyNavigation -%}
{{ renderNav(navPages, page.url) }}
