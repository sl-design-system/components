<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | SL Design System</title>
  <script>
    (function() {
      var scheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-color-scheme', scheme);
    })();
  </script>
  <link rel="stylesheet" href="/theme/fonts.css">
  <link id="theme-css" rel="stylesheet">
  <script>
    document.getElementById('theme-css').href = '/theme/' + document.documentElement.getAttribute('data-color-scheme') + '.css';
  </script>
  <link rel="stylesheet" href="/theme/global.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <div class="site-layout">
    <doc-sidebar>
      {% include "sidebar.njk" %}
    </doc-sidebar>

    <main class="content">
      <header>
        <h1>{{ title }}</h1>
        <div class="component-meta">
          {% if component.status %}
            <span class="status {{ component.status | lower }}">{{ component.status }}</span>
          {% endif %}
          {% if component.version %}
            <span class="version">v{{ component.version }}</span>
          {% endif %}
      </header>

      {{ content | safe }}
    </main>

    <doc-page-toc></doc-page-toc>
  </div>

  <script type="module" src="/js/main.js"></script>
</body>
</html>
