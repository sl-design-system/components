{
  "name": "@sl-design-system/shared",
  "version": "0.12.0",
  "description": "Shared code for the SL Design System components",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "exports": {
      ".": "./dist/index.js",
      "./controllers/new-focus-group.js": "./dist/controllers/new-focus-group.js",
      "./converters.js": "./dist/converters.js",
      "./date.js": "./dist/date.js",
      "./events.js": "./dist/events.js",
      "./helpers/forward-aria.js": "./dist/helpers/forward-aria.js",
      "./mixins.js": "./dist/mixins.js",
      "./package.json": "./package.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sl-design-system/components.git",
    "directory": "packages/components/shared"
  },
  "type": "module",
  "types": "./index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./controllers/new-focus-group.js": "./src/controllers/new-focus-group.ts",
    "./converters.js": "./src/converters.ts",
    "./date.js": "./src/date.ts",
    "./events.js": "./src/events.ts",
    "./helpers/forward-aria.js": "./src/helpers/forward-aria.ts",
    "./mixins.js": "./src/mixins.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "**/*.d.ts",
    "**/*.js",
    "**/*.js.map"
  ],
  "scripts": {
    "test": "echo \"Error: run tests from monorepo root.\" && exit 1"
  },
  "tsdown": {
    "entry": [
      "src/index.ts",
      "src/controllers/new-focus-group.ts",
      "src/converters.ts",
      "src/date.ts",
      "src/events.ts",
      "src/helpers/forward-aria.ts",
      "src/mixins.ts"
    ]
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@open-wc/dedupe-mixin": "^2.0.1",
    "lit": "^3.3.2"
  },
  "peerDependencies": {
    "@floating-ui/dom": "^1.6.5",
    "@open-wc/dedupe-mixin": "^2.0.1",
    "lit": "^3.1.4"
  }
}
