{
  "target": {
    "size-rem": {
      "font": {
        "1000": {
          "$value": "round_to({early.font-rem-base} * 5, 0)",
          "$type": "fontSize"
        },
        "150": {
          "$value": "round_to({early.font-rem-base} * 0.75, 0)",
          "$type": "fontSize"
        },
        "250": {
          "$value": "round_to({early.font-rem-base} * 1.25, 0)",
          "$type": "fontSize"
        },
        "500": {
          "$value": "round_to({early.font-rem-base} * 2.5, 0)",
          "$type": "fontSize"
        },
        "600": {
          "$value": "round_to({early.font-rem-base} * 3, 0)",
          "$type": "fontSize"
        },
        "175": {
          "$value": "round_to({early.font-rem-base} * 0.875, 0)",
          "$type": "fontSize"
        },
        "800": {
          "$value": "round_to({early.font-rem-base} * 4, 0)",
          "$type": "fontSize"
        },
        "200": {
          "$value": "round_to({early.font-rem-base} * 1, 0)",
          "$type": "fontSize"
        },
        "300": {
          "$value": "round_to({early.font-rem-base} * 1.5, 0)",
          "$type": "fontSize"
        },
        "400": {
          "$value": "round_to({early.font-rem-base} * 2, 0)",
          "$type": "fontSize"
        }
      }
    },
    "lineHeight": {
      "label": {
        "$value": "round_to({early.font-rem-base} * 1.33, 0)",
        "$type": "lineHeight"
      },
      "heading": {
        "md": {
          "$value": "round_to({early.font-rem-base} * 1.33, 0)",
          "$type": "lineHeight"
        },
        "lg": {
          "$value": "round_to({early.font-rem-base} * 1.27, 0)",
          "$type": "lineHeight"
        },
        "xl": {
          "$value": "round_to({early.font-rem-base} * 1.22, 0)",
          "$type": "lineHeight"
        }
      },
      "body": {
        "lg": {
          "$value": "round_to({early.font-rem-base} * 1.56, 0)",
          "$type": "lineHeight"
        },
        "sm": {
          "$value": "round_to({early.font-rem-base} * 1.43, 0)",
          "$type": "lineHeight"
        },
        "md": {
          "$value": "round_to({early.font-rem-base} * 1.5, 0)",
          "$type": "lineHeight"
        }
      }
    },
    "typeset-test": {
      "fontfamily": {
        "$value": "ABeZeh",
        "$type": "fontFamily"
      }
    },
    "lineHeigt": {
      "hero": {
        "$value": "round_to({early.font-rem-base} * 1.17, 0)",
        "$type": "lineHeight"
      }
    }
  },
  "early": {
    "font-rem-base": {
      "$value": "20",
      "$type": "number"
    }
  }
}