  "elevation": {
    "shadow": {
      "overflow": {
        "$value": [
          {
            "blur": "{size.200}",
            "type": "dropShadow",
            "color": "{color.shadow.overflow1}"
          }
        ],
        "$type": "shadow"
      },
      "overlay": {
        "$value": [
          {
            "y": "{size.075}",
            "blur": "{size.150}",
            "type": "dropShadow",
            "color": "{color.shadow.overlay1}",
            "spread": "-3"
          },
          {
            "y": "{size.150}",
            "blur": "{size.200}",
            "type": "dropShadow",
            "color": "{color.shadow.overlay2}"
          }
        ],
        "$type": "shadow"
      }
    }
